# ─────────────────────────────────────────────────────────────────────────────
# Outline instance
# ─────────────────────────────────────────────────────────────────────────────
# Base URL of your self-hosted Outline (no trailing slash)
OUTLINE_BASE_URL=https://outline.example.com

# API base (defaults to ${OUTLINE_BASE_URL}/api if OUTLINE_BASE_URL is set).
# Override only if your API lives somewhere else.
# OUTLINE_API_URL=https://outline.example.com/api

# ─────────────────────────────────────────────────────────────────────────────
# Outline OAuth 2.0 application
# Register at: Outline admin → Settings → API / Applications → New OAuth App
# Set the redirect URI to: ${MCP_SERVER_PUBLIC_URL}/oauth/callback
# ─────────────────────────────────────────────────────────────────────────────
OUTLINE_OAUTH_CLIENT_ID=
OUTLINE_OAUTH_CLIENT_SECRET=
# Space-separated list; adjust to the scopes your Outline version exposes
OUTLINE_OAUTH_SCOPES=read write

# ─────────────────────────────────────────────────────────────────────────────
# This MCP server
# ─────────────────────────────────────────────────────────────────────────────
# Publicly reachable URL of this MCP server (no trailing slash).
# Used for OAuth metadata, redirect URIs, and the resource identifier.
MCP_SERVER_PUBLIC_URL=https://mcp.example.com

# Bind address (default: 127.0.0.1). Use 0.0.0.0 behind a reverse proxy.
# OUTLINE_MCP_HOST=127.0.0.1
# OUTLINE_MCP_PORT=6060

# SQLite file for OAuth state and per-user session tokens
SESSION_DB_PATH=./data/sessions.db

# Optional Fastify log level (trace|debug|info|warn|error)
# LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# Dev-only fallback
# Set ALLOW_STATIC_KEY=1 to let the server fall back to a hardcoded Outline
# API key for requests without a Bearer token. DO NOT enable in production.
# ─────────────────────────────────────────────────────────────────────────────
OUTLINE_MCP_ALLOW_STATIC_KEY=0
# OUTLINE_API_KEY=your_outline_api_key_here
